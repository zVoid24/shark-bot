# =========================
# APP
# =========================
APP_NAME=sharkbot
APP_ENV=development
VERSION=1.0.0

# =========================
# TELEGRAM
# =========================
BOT_TOKEN=
OWNER_IDS=5160630771
# Comma-separated list of target group IDs to monitor for OTP messages
TARGET_GROUP_IDS=-1003422191454,-1003678266458

# Cooldown in seconds before user can change number again
COOLDOWN_SECONDS=10

# Optional webhook mode. Leave WEBHOOK_URL empty to use polling.
# For public-IP webhook without domain, use https://<PUBLIC_IP>/
WEBHOOK_URL=
LISTEN_PORT=8080

# Optional direct TLS listener (required if not using reverse proxy like nginx).
# Use absolute paths on server, e.g. C:\\certs\\webhook.crt and C:\\certs\\webhook.key
TLS_CERT_PATH=
TLS_KEY_PATH=

# Optional certificate uploaded to Telegram for self-signed IP certs.
WEBHOOK_CERT_PATH=

# =========================
# DATABASE (PostgreSQL)
# =========================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=8135
DB_NAME=sharkbot
DB_SSLMODE=disable

# =========================
# SERVER (optional, if API later)
# =========================
HTTP_PORT=8080
SECRET=sharkbot_secret

SCRAPER_USERNAME=
SCRAPER_PASSWORD=

# =========================
# BASE URL (optional)
# =========================
PUBLIC_BASE_URL=http://localhost:8080
