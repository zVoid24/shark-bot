# =========================
# APP
# =========================
APP_NAME=sharkbot
APP_ENV=development
VERSION=1.0.0

# =========================
# TELEGRAM
# =========================
BOT_TOKEN=
OWNER_IDS=5160630771
# Comma-separated list of target group IDs to monitor for OTP messages
TARGET_GROUP_IDS=-1003422191454,-1003678266458

# Cooldown in seconds before user can change number again
COOLDOWN_SECONDS=10

# Webhook is disabled by default so bot starts in polling mode.
ENABLE_WEBHOOK=false
WEBHOOK_URL=
LISTEN_PORT=8080

# =========================
# DATABASE (PostgreSQL)
# =========================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=8135
DB_NAME=sharkbot
DB_SSLMODE=disable

# =========================
# SERVER (optional, if API later)
# =========================
HTTP_PORT=8080
SECRET=sharkbot_secret

SCRAPER_USERNAME=
SCRAPER_PASSWORD=

# =========================
# BASE URL (optional)
# =========================
PUBLIC_BASE_URL=http://localhost:8080
